{
  "manifest_version": 3,
  "name": "Pit Crew — F1 Calendar",
  "version": "0.1.8",
  "description": "F1 race calendar, standings, and results with team color themes",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.jolpi.ca/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
